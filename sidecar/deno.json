{
  "nodeModulesDir": "auto",
  "imports": {
    "frida": "npm:frida@^17.7.3",
    "frida-compile": "npm:frida-compile@^19.0.4",
    "frida-java-bridge": "npm:frida-java-bridge@^7.0.12",
    "@types/frida-gum": "npm:@types/frida-gum@^18"
  },
  "tasks": {
    "dev": "deno run --watch --allow-all src/index.ts",
    "start": "deno run --allow-all src/index.ts",
    "install": "deno install",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "compilerOptions": {
    "strict": true
  }
}

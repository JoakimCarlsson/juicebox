{
  "nodeModulesDir": "auto",
  "imports": {
    "frida-compile": "npm:frida-compile@^19.0.4",
    "frida-java-bridge": "npm:frida-java-bridge@^7.0.12"
  },
  "tasks": {
    "build": "node_modules/.bin/frida-compile src/index.ts -o dist/agent.js",
    "watch": "node_modules/.bin/frida-compile src/index.ts -o dist/agent.js --watch",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any", "no-empty"]
    }
  }
}

# Bridge socket path (default: /tmp/juicebox.sock)
# JUICEBOX_SOCKET=/tmp/juicebox.sock

# LLM provider: openai, anthropic, or ollama
# JUICEBOX_LLM_PROVIDER=openai

# API key for the LLM provider
# JUICEBOX_LLM_API_KEY=sk-...

# Model override (default: gpt-4.1-mini for openai, claude-4.5-haiku for anthropic)
# JUICEBOX_LLM_MODEL=

# Base URL for ollama or custom endpoints
# JUICEBOX_LLM_BASE_URL=http://localhost:11434/v1
